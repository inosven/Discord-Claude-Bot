# Get your bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

# Optional: restrict bot to specific channel IDs (comma-separated)
# In these channels the bot responds to ALL messages (no @mention needed)
# Leave empty to require @mention in all channels
DISCORD_CHANNEL_ID=

# Optional: default working directory for Claude
# Leave empty to use the bot's own directory
CLAUDE_WORKING_DIR=
